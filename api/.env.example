# AEGIS API — environment variables (copy to .env and customize)

ENV=dev
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# --- Database ---
DATABASE_URL=postgresql+asyncpg://aegis:aegis@postgres:5432/aegis
DATABASE_URL_SYNC=postgresql+psycopg2://aegis:aegis@postgres:5432/aegis

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Keycloak ---
# URL used by the API container to fetch JWKS (internal docker network).
KEYCLOAK_URL=http://keycloak:8080
# URL that appears in the `iss` claim of issued tokens — must match what
# the browser/cURL talked to. Pinning it lets the API validate tokens
# regardless of which side issued them.
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=aegis
KEYCLOAK_CLIENT_ID=aegis-api
KEYCLOAK_AUDIENCE=aegis-api

# --- Ingest API key (rotate in production) ---
INGEST_API_KEY=dev-ingest-key-change-me

# --- Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
FERNET_KEY=REPLACE_ME_WITH_44_CHAR_BASE64_URLSAFE_KEY

# --- Claude API (Phase 4+) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Sentry ---
# SENTRY_DSN=

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
